# Copy to .env and fill in. `docker compose up` reads this file.
# Local dev runs with SKRIFT_ENV=development, which uses a SQLite database
# (app.db), so most of these only matter once a given feature is exercised.

# --- Core ---
# Secret used to sign sessions/cookies. Any long random string.
SECRET_KEY=change-me-to-a-long-random-string

# Production Postgres. In local dev the DB falls back to SQLite (app.db),
# so this is only needed for production / Postgres.
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/zech_sh

# Cache / sessions.
REDIS_URL=redis://localhost:6379/0

# --- Admin sign-in (Google OAuth) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
AUTH_REDIRECT_BASE_URL=http://localhost:8888

# --- Media uploads (S3 / DigitalOcean Spaces) ---
SPACES_ACCESS_KEY_ID=
SPACES_SECRET_ACCESS_KEY=

# --- AI features (scan search + aichat) ---
GOOGLE_API_KEY=        # Gemini models
OPENAI_API_KEY=        # OpenAI models
BRAVE_API_KEY=         # web search
JINA_API_KEY=          # page reader
AICHAT_TOKEN_SECRET=   # signs aichat device tokens
